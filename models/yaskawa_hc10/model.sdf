    <link name="link_3_u">
      <pose relative_to="joint_3_u">0 0 0 0 0 0</pose>
      <inertial>
        <mass>6.0</mass>
        <inertia>
          <ixx>0.05</ixx>
          <iyy>0.05</iyy>
          <izz>0.04</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
