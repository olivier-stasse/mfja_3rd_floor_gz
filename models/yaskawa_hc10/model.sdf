          </mesh>
        </geometry>
      </collision>
    </link>

    <link name="link_2_l">
      <pose relative_to="joint_2_l">0 0 0 0 0 0</pose>
      <inertial>
        <mass>7.0</mass>
        <inertia>
          <ixx>0.06</ixx>
          <iyy>0.06</iyy>
          <izz>0.05</izz>
          <ixy>0</ixy>
