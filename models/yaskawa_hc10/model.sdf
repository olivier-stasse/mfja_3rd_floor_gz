<?xml version="1.0"?>
<sdf version="1.9">
  <model name="yaskawa_hc10">
    <self_collide>false</self_collide>
    <allow_auto_disable>false</allow_auto_disable>

    <link name="base_link">
      <inertial>
        <pose>0 0 0.10 0 0 0</pose>
        <mass>24.0</mass>
        <inertia>
          <ixx>0.35</ixx>
          <iyy>0.35</iyy>
          <izz>0.30</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="base_link_visual">
        <geometry>
          <mesh>
            <uri>model://yaskawa_hc10/meshes/hc10/visual/base_link.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="base_link_collision">
        <geometry>
          <mesh>
            <uri>model://yaskawa_hc10/meshes/hc10/collision/base_link.stl</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <link name="link_1_s">
      <pose relative_to="joint_1_s">0 0 0 0 0 0</pose>
      <inertial>
        <mass>8.5</mass>
        <inertia>
          <ixx>0.07</ixx>
          <iyy>0.07</iyy>
          <izz>0.05</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
