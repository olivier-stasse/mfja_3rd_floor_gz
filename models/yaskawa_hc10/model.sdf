    <link name="link_4_r">
      <pose relative_to="joint_4_r">0 0 0 0 0 0</pose>
      <inertial>
        <mass>3.5</mass>
        <inertia>
          <ixx>0.03</ixx>
          <iyy>0.03</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
