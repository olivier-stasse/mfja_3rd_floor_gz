    <link name="tool0">
      <pose relative_to="joint_6_t-tool0">0 0 0 0 0 0</pose>
    </link>
    <link name="base">
      <pose relative_to="base_link-base">0 0 0 0 0 0</pose>
    </link>

    <joint name="world_joint" type="fixed">
      <parent>world</parent>
      <child>base_link</child>
    </joint>

    <joint name="joint_1_s" type="revolute">
      <parent>base_link</parent>
      <child>link_1_s</child>
      <pose relative_to="base_link">0 0 0.275 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265359</lower>
          <upper>3.14159265359</upper>
          <effort>700.0</effort>
          <velocity>2.26892802759</velocity>
        </limit>
        <dynamics>
          <damping>0.7</damping>
          <friction>0.05</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_2_l" type="revolute">
      <parent>link_1_s</parent>
      <child>link_2_l</child>
      <pose relative_to="link_1_s">0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-3.14159265359</lower>
          <upper>3.14159265359</upper>
          <effort>700.0</effort>
          <velocity>2.26892802759</velocity>
        </limit>
        <dynamics>
          <damping>0.7</damping>
          <friction>0.05</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_3_u" type="revolute">
      <parent>link_2_l</parent>
      <child>link_3_u</child>
      <pose relative_to="link_2_l">0 0 0.700 0 0 0</pose>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>-0.08726646260</lower>
          <upper>6.19591884458</upper>
          <effort>260.0</effort>
          <velocity>3.14159265359</velocity>
        </limit>
        <dynamics>
          <damping>0.6</damping>
          <friction>0.05</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_4_r" type="revolute">
      <parent>link_3_u</parent>
      <child>link_4_r</child>
      <pose relative_to="link_3_u">0 0 -0.500 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265359</lower>
          <upper>3.14159265359</upper>
          <effort>39.20</effort>
          <velocity>3.14159265359</velocity>
        </limit>
        <dynamics>
          <damping>0.9</damping>
          <friction>0.10</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_5_b" type="revolute">
      <parent>link_4_r</parent>
      <child>link_5_b</child>
      <pose relative_to="link_4_r">0 0.162 0 0 0 0</pose>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>-3.14159265359</lower>
          <upper>3.14159265359</upper>
          <effort>31.36</effort>
          <velocity>4.36332312999</velocity>
        </limit>
        <dynamics>
          <damping>0.7</damping>
          <friction>0.08</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_6_t" type="revolute">
      <parent>link_5_b</parent>
      <child>link_6_t</child>
      <pose relative_to="link_5_b">0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265359</lower>
          <upper>3.14159265359</upper>
          <effort>31.36</effort>
          <velocity>4.36332312999</velocity>
        </limit>
        <dynamics>
          <damping>0.6</damping>
          <friction>0.06</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_6_t-tool0" type="fixed">
      <parent>link_6_t</parent>
      <child>tool0</child>
      <pose relative_to="link_6_t">0 0 -0.130 3.14159265359 0 0</pose>
    </joint>

    <joint name="base_link-base" type="fixed">
      <parent>base_link</parent>
      <child>base</child>
      <pose relative_to="base_link">0 0 0.275 0 0 0</pose>
    </joint>

    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>joint_1_s</joint_name>
      <joint_name>joint_2_l</joint_name>
      <joint_name>joint_3_u</joint_name>
      <joint_name>joint_4_r</joint_name>
      <joint_name>joint_5_b</joint_name>
      <joint_name>joint_6_t</joint_name>
    </plugin>

    <plugin
      filename="gz-sim-joint-trajectory-controller-system"
      name="gz::sim::systems::JointTrajectoryController">
      <joint_name>joint_1_s</joint_name>
      <initial_position>0.0</initial_position>
      <position_p_gain>170.0</position_p_gain>
      <position_i_gain>0.10</position_i_gain>
      <position_d_gain>25.0</position_d_gain>
      <position_i_min>-2.0</position_i_min>
      <position_i_max>2.0</position_i_max>
      <position_cmd_min>-340.0</position_cmd_min>
      <position_cmd_max>340.0</position_cmd_max>

      <joint_name>joint_2_l</joint_name>
      <initial_position>0.0</initial_position>
      <position_p_gain>170.0</position_p_gain>
      <position_i_gain>0.10</position_i_gain>
      <position_d_gain>25.0</position_d_gain>
      <position_i_min>-2.0</position_i_min>
      <position_i_max>2.0</position_i_max>
      <position_cmd_min>-340.0</position_cmd_min>
      <position_cmd_max>340.0</position_cmd_max>

      <joint_name>joint_3_u</joint_name>
      <initial_position>0.0</initial_position>
      <position_p_gain>120.0</position_p_gain>
      <position_i_gain>0.08</position_i_gain>
      <position_d_gain>18.0</position_d_gain>
      <position_i_min>-1.5</position_i_min>
      <position_i_max>1.5</position_i_max>
      <position_cmd_min>-220.0</position_cmd_min>
      <position_cmd_max>220.0</position_cmd_max>

      <joint_name>joint_4_r</joint_name>
      <initial_position>0.0</initial_position>
      <position_p_gain>40.0</position_p_gain>
      <position_i_gain>0.04</position_i_gain>
      <position_d_gain>6.0</position_d_gain>
      <position_i_min>-0.8</position_i_min>
      <position_i_max>0.8</position_i_max>
      <position_cmd_min>-90.0</position_cmd_min>
      <position_cmd_max>90.0</position_cmd_max>

      <joint_name>joint_5_b</joint_name>
